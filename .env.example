# ============================================================================
# 9 Enterprises — Environment Variable Reference
# Generated: 2026-04-05 by FORT (Security Lead, 9 Enterprises)
# FORT C-06: Closes the .env documentation gap from Tee's credential inventory.
#
# RULES:
# - Copy this file to .env and fill in your values.
# - NEVER commit .env to git (it is gitignored).
# - SQLITE_ENCRYPTION_KEY is stored in macOS Keychain, not .env (FORT C-03).
# - PCI/PII data (AMEX card, SSN, DL) is stored in ~/.9-secrets/pii.env (FORT C-01).
# - All values marked [REQUIRED] must be set or the referenced process will exit(1).
# - All values marked [OPTIONAL] have safe defaults or are feature-gated.
# ============================================================================

# ─── AI Providers ────────────────────────────────────────────────────────────

# Anthropic API key — used by voice-server, jules-telegram, kids-mentor,
# pilot-server, trinity-agent, underwriter-api, open-terminal
# Format: sk-ant-api03-...
# [REQUIRED] for all AI-dependent services
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Separate Anthropic key for comms-hub (TC = "Terminal Claude" — keeps comms
# billing separate from product billing). Can be the same key as above.
# [REQUIRED] for comms-hub AI relay mode
ANTHROPIC_API_KEY_TC=sk-ant-api03-your-tc-key-here

# ─── Telegram ────────────────────────────────────────────────────────────────

# Primary Telegram bot token (comms-hub, cloud-worker)
# Get from BotFather: https://t.me/botfather → /newbot or /mybots
# [REQUIRED] for comms-hub
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Jasson's Telegram user ID (used by comms-hub to route messages to owner)
# Find yours: message @userinfobot on Telegram
# [REQUIRED] for comms-hub message routing
TELEGRAM_CHAT_ID=your-chat-id-here

# Jules's separate bot token — different bot, different personality
# C-05: must NOT have a hardcoded fallback in source. process.exit(1) if missing.
# [REQUIRED] for jules-telegram.mjs
JULES_TELEGRAM_BOT_TOKEN=your-jules-bot-token-here

# ─── Voice / ElevenLabs ──────────────────────────────────────────────────────

# ElevenLabs TTS API key
# Get from: https://elevenlabs.io/app/settings/api-keys
# [REQUIRED] for voice-server
ELEVENLABS_API_KEY=sk_your-key-here

# ElevenLabs voice persona ID for 9's voice
# If not set, voice-server falls back to hardcoded default "4XMC8Vdi6YFsmti2NFdp"
# [OPTIONAL]
ELEVENLABS_VOICE_ID=your-voice-id-here

# ─── Telephony (Twilio) ──────────────────────────────────────────────────────

# Twilio credentials — account SID, auth token, phone numbers
# Get from: https://console.twilio.com
# [REQUIRED] for comms-hub voice + SMS, pilot-server

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here

# Primary outbound number for comms-hub
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Backup numbers (SMS relay)
TWILIO_BACKUP_1=+1XXXXXXXXXX
TWILIO_BACKUP_2=+1XXXXXXXXXX
TWILIO_BACKUP_3=+1XXXXXXXXXX

# Outbound number for Kyle Cabezas SMS (pilot-server)
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ─── Email (Gmail App Password + Resend) ─────────────────────────────────────

# Gmail App Password for comms-hub inbound/outbound email
# Generate at: https://myaccount.google.com/apppasswords
# NOTE: App passwords are permanent — rotate annually. See H-01 in credential inventory.
# [OPTIONAL] — email channel disabled if not set
GMAIL_APP_PASSWORD=your-16-char-app-password

# Resend API keys (transactional email with proper FROM domain)
# Get from: https://resend.com/api-keys
# [OPTIONAL] — for future email channels
RESEND_API_KEY=re_your-key-here
RESEND_API_KEY_FULL=re_your-full-key-here

# ─── Database (Supabase) ─────────────────────────────────────────────────────

# Supabase project URL (not a secret — safe to expose)
# Get from: supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (limited access, respects RLS)
# Use this for all standard comms-hub sync operations (FORT C-02)
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service key (bypasses RLS — admin scope)
# C-02: Use ONLY in scripts that require admin access (backup-memory.mjs storage ops,
# supabase-migrate.mjs schema migrations). Never use in comms-hub.
# [OPTIONAL for comms-hub] [REQUIRED for backup-memory, supabase-migrate]
SUPABASE_SERVICE_KEY=your-service-key-here

# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────

# Neon DB connection string — full credentials included
# If leaked: full read/write access to cloud Neon DB. Treat as a secret.
# Get from: neon.tech → your project → Connection Details
# [OPTIONAL] — used for supplemental cloud DB if enabled
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ─── SQLite / Memory Database ────────────────────────────────────────────────

# SQLCipher encryption key for 9-memory.db
# C-03: This key is stored in macOS Keychain, NOT in .env.
# The key and the encrypted database must not be co-located.
# To store: security add-generic-password -a "9-enterprises" -s "SQLITE_ENCRYPTION_KEY" -w <64-hex-key>
# To retrieve: security find-generic-password -a "9-enterprises" -s "SQLITE_ENCRYPTION_KEY" -w
# In dev/CI without Keychain: set this env var as a fallback only.
# [OPTIONAL in .env — use Keychain in production]
# SQLITE_ENCRYPTION_KEY=<set in Keychain, not here>

# ─── Trading (Alpaca) ────────────────────────────────────────────────────────

# Alpaca paper trading keys (default — no real money)
# Get from: https://app.alpaca.markets/paper-account/overview → API Keys
# [REQUIRED] for trader9-bot in paper mode
ALPACA_API_KEY=your-paper-api-key
ALPACA_SECRET_KEY=your-paper-secret-key

# Alpaca live (real money) trading keys
# C-04: Presence of these keys alone does NOT activate live trading.
# You MUST also set ALPACA_LIVE_ENABLED=true to enable real-money trading.
# This dual-gate prevents accidental live activation during dev/testing.
# [OPTIONAL] — paper mode is the default
ALPACA_LIVE_API_KEY=your-live-api-key
ALPACA_LIVE_SECRET_KEY=your-live-secret-key

# C-04 live trading opt-in flag — MUST be "true" (exact string) to enable
# live trading. If missing or any other value, paper mode is forced.
# Default: not set = paper mode
# [OPTIONAL — default is paper mode]
ALPACA_LIVE_ENABLED=false

# Alpaca account credentials (for MFA-based login flows)
# [OPTIONAL] — only needed for scripts that do browser-based auth
ALPACA_EMAIL=your-alpaca-email@example.com
ALPACA_PASSWORD=your-alpaca-password
ALPACA_MFA_SECRET=your-totp-secret
ALPACA_MFA_EMERGENCY=your-emergency-code

# Maximum daily portfolio loss before circuit breaker halts trading (percentage)
# Example: 3.0 = stop trading if portfolio drops 3% in one day
# [OPTIONAL — defaults to 3.0 if not set]
MAX_DAILY_LOSS_PCT=3.0

# ─── Cloud / Tunnel ──────────────────────────────────────────────────────────

# Cloudflare Worker URL (cloud standin when Mac is down)
# Set after deploying cloud-worker/ with wrangler
CLOUD_WORKER_URL=https://your-worker.workers.dev

# Shared secret between Mac hub and Cloudflare Worker for mutual auth
# Generate: openssl rand -hex 32
# [REQUIRED] for cloud sync
CLOUD_SECRET=your-32-byte-hex-secret

# Cloudflare tunnel URL for voice server (changes on every tunnel restart)
# Updated dynamically by the hub — stale value here is low risk
# [OPTIONAL]
TUNNEL_URL=https://your-tunnel-subdomain.trycloudflare.com

# Cloudflare API tokens
# Full Access Token: Pages + DNS + Zone management
# Get from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=cfut_your-token
CLOUDFLARE_PAGES_TOKEN=cfut_your-pages-token

# ─── Internal Auth ───────────────────────────────────────────────────────────

# Hub API secret — protects the /context (shared state write) endpoint
# H-03: This MUST be set in production. If not set, /context endpoint is OPEN.
# Generate: openssl rand -hex 32
# [REQUIRED in production]
HUB_API_SECRET=your-32-byte-hex-secret

# ─── Social Media (X / Twitter) ──────────────────────────────────────────────

# X (Twitter) API credentials for x9 posting agent
# Get from: https://developer.twitter.com/en/portal/dashboard
# [OPTIONAL] — CLI tool only, not a running service
X_API_KEY=your-api-key
X_API_SECRET=your-api-secret
X_ACCESS_TOKEN=your-access-token
X_ACCESS_TOKEN_SECRET=your-access-secret
X_OAUTH2_CLIENT_ID=your-oauth2-client-id
X_OAUTH2_CLIENT_SECRET=your-oauth2-client-secret

# X.com account for x9 agent
X9_X_USERNAME=your-x-username
X9_X_EMAIL=your-x-email@example.com
X9_X_PASSWORD=your-x-password

# ─── PII / Contact Numbers ───────────────────────────────────────────────────

# Owner and family phone numbers (PII — H-04)
# Used by comms-hub for routing and notifications
# [REQUIRED] for correct message routing
JASSON_PHONE=+1XXXXXXXXXX
JAMIE_PHONE=+1XXXXXXXXXX

# Kyle Cabezas (FreeAgent9 pilot user) phone
KYLE_PHONE=+1XXXXXXXXXX
JULES_KYLEC_RECIPIENT_PHONE=+1XXXXXXXXXX

# Jules legacy recipient (jules-server.mjs — verify if still needed)
# [ORPHAN — may be unused]
JULES_RECIPIENT_PHONE=+1XXXXXXXXXX

# ─── Stripe ──────────────────────────────────────────────────────────────────

# Stripe API keys (payment processing)
# Get from: https://dashboard.stripe.com/apikeys
# [OPTIONAL] — for products with Stripe checkout
STRIPE_PUBLISHABLE_KEY=pk_live_your-key
STRIPE_SECRET_KEY=sk_live_your-key

# ─── Third-Party Services ────────────────────────────────────────────────────

# HeyGen video generation API
# Get from: https://app.heygen.com/settings → API Keys
HEYGEN_API_KEY=sk_your-key

# D-ID video generation API
DID_API_KEY=base64-encoded-email:key

# OpenWeather API (pilot-server weather features)
# Get from: https://openweathermap.org/api
# [OPTIONAL]
OPENWEATHER_API_KEY=your-key

# xAI (Grok) API key
# Get from: https://console.x.ai
XAI_API_KEY=xai-your-key

# ─── Domain / DNS ────────────────────────────────────────────────────────────

# DNSimple domain registrar credentials
DNSIMPLE_ACCOUNT_ID=your-account-id
DNSIMPLE_API_TOKEN=dnsimple_a_your-token
DNSIMPLE_EMAIL=your-email@example.com
DNSIMPLE_PASSWORD=your-password

# ─── Account Credentials ─────────────────────────────────────────────────────

# Proton accounts (9 Enterprise communications)
X9_PROTON_EMAIL=x9agent@proton.me
X9_PROTON_PASSWORD=your-password
PROTON_9E_EMAIL=9enterprises@proton.me
PROTON_9E_PASSWORD=your-password
# PROTON_9E_RECOVERY — seed phrase — stored in ~/.9-secrets/pii.env (FORT C-01)

# Digital Ocean account (for cloud infrastructure)
DO_EMAIL=your-email@example.com
DO_PASSWORD=your-password

# Reddit account for x9 agent
X9_REDDIT_USERNAME=your-username
X9_REDDIT_PASSWORD=your-password

# ─── Feature Flags (Legacy / POC) ────────────────────────────────────────────

# Dominos pizza order POC — env vars read by food-order-poc.mjs
# NOTE: C-01 — NEVER put actual card data here. Use ~/.9-secrets/pii.env.
# food-order-poc.mjs is a POC script, not a running service.
# [ORPHAN — POC only]
DOMINOS_FIRST_NAME=Test
DOMINOS_LAST_NAME=User
DOMINOS_PHONE=5135551234
DOMINOS_EMAIL=test@example.com
DOMINOS_ADDRESS=123 Main St, Cincinnati OH 45255
DOMINOS_CARD_NUMBER=<use-tokenized-payment, never real PAN>
DOMINOS_CARD_EXPIRY=<use-tokenized-payment>
DOMINOS_CARD_CVV=<use-tokenized-payment>
DOMINOS_CARD_ZIP=<use-tokenized-payment>
DOMINOS_TIP=5.00
# Set to "true" to actually place a Dominos order (default: dry-run only)
PLACE_ORDER=false

# Legacy trading bot flags (trading-bot.mjs — superseded by trader9-bot.mjs)
# [ORPHAN — legacy only]
TRIGGER_SENTIMENT=true

# OC relay lockdown flag — prevents OC from impersonating 9 in relay mode
# Set to "true" to enforce lockdown (recommended in production)
# [OPTIONAL — default behavior in comms-hub]
OC_RELAY_LOCKDOWN=true

# Pilot server port override
# [OPTIONAL — defaults to 3456]
PORT=3456

# Tunnel URL for telegram-relay.mjs (legacy relay script)
# [ORPHAN — verify if still needed]
MAC_TUNNEL_URL=https://your-tunnel.trycloudflare.com

# LLC and Business Identity
# [OPTIONAL — used for identity/verification scripts]
LLC_ENTITY_NUMBER=your-entity-number
LLC_DOC_ID=your-doc-id
EIN=your-ein
EIN_NAME_CONTROL=your-ein-name-control

# ─── CAPTCHA / SMS Verification ──────────────────────────────────────────────
# Used for automated account verification flows
# [OPTIONAL]
CAPMONSTER_API_KEY=your-key
TWO_CAPTCHA_API_KEY=your-key
MOBILESMS_API_KEY=your-key

# ─── NOT IN .env — See Security Notes ────────────────────────────────────────
# The following are intentionally NOT in .env:
#
# SQLITE_ENCRYPTION_KEY → macOS Keychain (FORT C-03)
#   security find-generic-password -a "9-enterprises" -s "SQLITE_ENCRYPTION_KEY" -w
#
# AMEX_CARD, AMEX_CVV, AMEX_EXP, AMEX_NAME, AMEX_ADDRESS → ~/.9-secrets/pii.env (FORT C-01)
# SSN, DL_NUMBER, DL_DOB, MAC_PASSWORD, PROTON_9E_RECOVERY → ~/.9-secrets/pii.env (FORT C-01)
#   chmod 600 ~/.9-secrets/pii.env — never commit, never source in public processes
#
# Cloud Worker secrets (TELEGRAM_BOT_TOKEN, CLOUD_SECRET, ANTHROPIC_API_KEY, CHAT_ID, STATE)
# → Set as Cloudflare Worker secrets via: wrangler secret put <KEY>
#
# Command Hub Next.js env (NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY,
#   SUPABASE_SERVICE_ROLE_KEY) → command-hub/.env.local (see command-hub/.env.local.example)
#
# ─── Rotation Schedule ───────────────────────────────────────────────────────
# Per credential-inventory.md:
# - ANTHROPIC_API_KEY: rotate on any suspected compromise or quarterly
# - TELEGRAM_BOT_TOKEN, JULES_TELEGRAM_BOT_TOKEN: rotate via BotFather immediately if leaked
# - GMAIL_APP_PASSWORD: rotate annually (H-01 — permanent credential)
# - ALPACA live keys: rotate if ever in a public repo; verify IP allowlist active
# - SUPABASE_SERVICE_KEY: rotate if leaked; audit git history first
# - SQLITE_ENCRYPTION_KEY: DO NOT rotate without re-encrypting the database first
